{
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/ads/(.*)", "destination": "/ads/$1" },
    { "source": "/social-media/(.*)", "destination": "/social-media/$1" },
    { "source": "/email/(.*)", "destination": "/email/$1" },
    { "source": "/print/(.*)", "destination": "/print/$1" }
  ]
}
