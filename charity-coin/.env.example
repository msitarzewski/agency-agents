# =============================================================================
# Charity Coin - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://charity:charity@localhost:5432/charity_coin

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Blockchain / RPC
# -----------------------------------------------------------------------------
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# -----------------------------------------------------------------------------
# Deployed Contract Addresses
# -----------------------------------------------------------------------------
CONVERSION_ENGINE_ADDRESS=0x
CHARITY_COIN_ADDRESS=0x
CAUSE_TOKEN_FACTORY_ADDRESS=0x

# -----------------------------------------------------------------------------
# Known External Contract Addresses (Base Mainnet)
# -----------------------------------------------------------------------------
UNISWAP_V3_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
ADMIN_API_KEY=change-me-to-a-secure-random-string

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# -----------------------------------------------------------------------------
# Contracts (deployment only - do NOT use in production services)
# -----------------------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=0x
ETHERSCAN_API_KEY=your-basescan-api-key

# -----------------------------------------------------------------------------
# Operations
# -----------------------------------------------------------------------------
OPS_WALLET_ADDRESS=0x
